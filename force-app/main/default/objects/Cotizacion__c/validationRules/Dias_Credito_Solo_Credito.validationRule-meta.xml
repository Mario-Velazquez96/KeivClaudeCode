<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Dias_Credito_Solo_Credito</fullName>
    <active>true</active>
    <errorConditionFormula>AND(TEXT(Condicion_Pago__c) != "Credito", NOT(ISBLANK(Dias_Credito__c)), Dias_Credito__c > 0)</errorConditionFormula>
    <errorMessage>Dias de Credito solo aplica cuando la condicion de pago es Credito.</errorMessage>
</ValidationRule>
