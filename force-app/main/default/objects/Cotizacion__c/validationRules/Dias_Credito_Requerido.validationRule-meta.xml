<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Dias_Credito_Requerido</fullName>
    <active>true</active>
    <errorConditionFormula>AND(TEXT(Condicion_Pago__c) = "Credito", ISBLANK(Dias_Credito__c))</errorConditionFormula>
    <errorMessage>Dias de Credito es obligatorio cuando la condicion de pago es Credito.</errorMessage>
</ValidationRule>
